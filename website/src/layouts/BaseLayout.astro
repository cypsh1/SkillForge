---
interface Props {
  title?: string;
  description?: string;
  lang?: string;
  locale?: 'zh' | 'en';
}

const {
  title = 'SkillForge',
  description = 'OpenClaw Skill 可视化配置工具',
  lang = 'zh-CN',
  locale = 'zh',
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const siteOrigin = 'https://cypsh1.github.io';
const canonicalUrl = `${siteOrigin}${base}${locale}/`;
const ogImageUrl = `${siteOrigin}${base}og-image.png`;

const altLocale = locale === 'zh' ? 'en' : 'zh';
const altLang = locale === 'zh' ? 'en-US' : 'zh-CN';
const currentLang = locale === 'zh' ? 'zh-CN' : 'en-US';
const altUrl = `${siteOrigin}${base}${altLocale}/`;
const xDefaultUrl = `${siteOrigin}${base}en/`;

const ogLocale = locale === 'zh' ? 'zh_CN' : 'en_US';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'SkillForge',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Windows, Linux',
  url: canonicalUrl,
  image: ogImageUrl,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  softwareVersion: '1.1.0',
  author: {
    '@type': 'Organization',
    name: 'SkillForge',
    url: `${siteOrigin}${base}`,
  },
  license: 'https://opensource.org/licenses/MIT',
  inLanguage: [currentLang],
};
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090b" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={currentLang} href={canonicalUrl} />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="SkillForge" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen antialiased">
    <slot />

    <!-- Scroll reveal animation -->
    <script>
      const reveals = document.querySelectorAll('.reveal');
      // Immediately reveal elements already in viewport
      reveals.forEach((el) => {
        if (el.getBoundingClientRect().top < window.innerHeight) {
          el.classList.add('revealed');
        }
      });
      // Observe the rest for scroll-triggered reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      reveals.forEach((el) => {
        if (!el.classList.contains('revealed')) observer.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
