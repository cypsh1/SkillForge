---
import type zh from '../i18n/zh.json';

interface Props {
  t: typeof zh;
}

const { t } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const releasesUrl = 'https://github.com/cypsh1/SkillForge/releases';
---

<section class="relative flex min-h-screen flex-col items-center justify-center px-6 pt-16 text-center">
  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-[radial-gradient(ellipse_at_center,rgba(134,59,255,0.15),transparent_70%)]"></div>
  </div>

  <div class="relative z-10 flex max-w-3xl flex-col items-center gap-6">
    <!-- Badge -->
    <span class="rounded-full border border-border px-4 py-1.5 text-xs text-muted-foreground">
      {t.hero.badge}
    </span>

    <!-- Headline -->
    <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
      {t.hero.title}
    </h1>

    <!-- Subtitle -->
    <p class="max-w-xl text-lg leading-relaxed text-muted-foreground">
      {t.hero.subtitle}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col gap-3 sm:flex-row">
      <a href={releasesUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center rounded-lg bg-gradient-to-r from-brand-purple to-brand-cyan px-6 py-3 text-sm font-medium text-white transition hover:opacity-90">
        {t.hero.cta_download}
      </a>
      <a href="https://github.com/cypsh1/SkillForge" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 rounded-lg border border-border px-6 py-3 text-sm font-medium text-foreground transition hover:bg-muted">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        {t.hero.cta_github}
      </a>
    </div>

    <!-- Metrics bar -->
    <div class="mt-4 flex flex-wrap items-center justify-center gap-6 sm:gap-8">
      {t.hero.metrics.map((m) => (
        <div class="flex items-baseline gap-1.5">
          <span class="text-2xl font-bold text-foreground">{m.value}</span>
          <span class="text-sm text-muted-foreground">{m.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Product screenshot -->
  <div class="relative z-10 mt-16 w-full max-w-5xl">
    <div class="overflow-hidden rounded-xl border border-border shadow-2xl shadow-brand-purple/5">
      <img src={`${base}screenshots/hero-overview.png`} alt="SkillForge workspace" class="w-full" loading="eager" />
    </div>
  </div>
</section>
