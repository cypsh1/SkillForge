---
import type zh from '../i18n/zh.json';

interface Props {
  t: typeof zh;
}

const { t } = Astro.props;

const statusStyles: Record<string, string> = {
  done: 'bg-accent-green border-accent-green',
  progress: 'bg-accent-amber border-accent-amber animate-pulse',
  planned: 'bg-muted-foreground/40 border-muted-foreground/40',
};

const tagStyles: Record<string, string> = {
  done: 'border-accent-green/30 text-accent-green',
  progress: 'border-accent-amber/30 text-accent-amber',
  planned: 'border-muted-foreground/30 text-muted-foreground',
};
---

<section id="roadmap" class="mx-auto max-w-3xl px-6 py-24">
  <h2 class="mb-12 text-center text-3xl font-bold text-foreground">{t.roadmap.title}</h2>

  <div class="relative">
    <!-- Timeline line -->
    <div class="absolute left-4 top-0 bottom-0 w-px bg-border md:left-1/2"></div>

    <div class="flex flex-col gap-12">
      {t.roadmap.versions.map((v) => (
        <div class="relative pl-12 md:pl-0 md:text-center">
          <!-- Dot -->
          <div class={`absolute left-2.5 top-1.5 h-3 w-3 rounded-full border-2 md:left-1/2 md:-translate-x-1/2 ${statusStyles[v.status]}`}></div>

          <!-- Content -->
          <div class="md:mx-auto md:max-w-md">
            <div class="flex items-center gap-3 md:justify-center">
              <h3 class="text-xl font-bold text-foreground">{v.version}</h3>
              <span class={`rounded-full border px-2.5 py-0.5 text-xs ${tagStyles[v.status]}`}>{v.statusLabel}</span>
            </div>
            <div class="mt-3 flex flex-wrap gap-2 md:justify-center">
              {v.features.map((f) => (
                <span class="rounded-md border border-border bg-muted px-2.5 py-1 text-xs text-muted-foreground">{f}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
