---
import { getAlternateLocale, getAlternateLabel } from '../i18n';
import type zh from '../i18n/zh.json';

interface Props {
  locale: string;
  t: typeof zh;
}

const { locale, t } = Astro.props;
const altLocale = getAlternateLocale(locale);
const altLabel = getAlternateLabel(locale);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-background/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- Logo -->
    <a href={`${base}${locale}/`} class="flex items-center gap-2 text-lg font-semibold text-foreground">
      <img src={`${base}favicon.svg`} alt="SkillForge" class="h-7 w-7" />
      SkillForge
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex">
      <a href="#pain-points" class="text-sm text-muted-foreground transition hover:text-foreground">{t.nav.features}</a>
      <a href="#download" class="text-sm text-muted-foreground transition hover:text-foreground">{t.nav.download}</a>
      <a href="#roadmap" class="text-sm text-muted-foreground transition hover:text-foreground">{t.nav.roadmap}</a>
      <a href={`${base}${altLocale}/`} class="rounded-md border border-border px-2.5 py-1 text-xs text-muted-foreground transition hover:text-foreground">{altLabel}</a>
      <a href="https://github.com/cypsh1/SkillForge" target="_blank" rel="noopener" class="text-muted-foreground transition hover:text-foreground" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="flex items-center md:hidden text-muted-foreground" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border px-6 py-4 md:hidden">
    <div class="flex flex-col gap-4">
      <a href="#pain-points" class="text-sm text-muted-foreground">{t.nav.features}</a>
      <a href="#download" class="text-sm text-muted-foreground">{t.nav.download}</a>
      <a href="#roadmap" class="text-sm text-muted-foreground">{t.nav.roadmap}</a>
      <a href={`${base}${altLocale}/`} class="text-sm text-muted-foreground">{altLabel}</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
