---
import type zh from '../i18n/zh.json';

interface Props {
  t: typeof zh;
}

const { t } = Astro.props;

const iconPaths: Record<string, string> = {
  edit: '<path d="M21 12a9 9 0 1 1-9-9 9 9 0 0 1 9 9Z"/><path d="m9 12 2 2 4-4"/>',
  connect: '<circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/><path d="M12 6v5m0 2v5m5-6h-4m-2 0H6"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67 0C8.5 20.5 5 18 5 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C15.5 3.8 18 5 20 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
};

const colors = [
  'border-accent-blue/30 bg-accent-blue/10 text-accent-blue',
  'border-accent-purple/30 bg-accent-purple/10 text-accent-purple',
  'border-accent-green/30 bg-accent-green/10 text-accent-green',
];
---

<section id="pillars" class="reveal mx-auto max-w-6xl px-6 py-24">
  <h2 class="mb-12 text-center text-3xl font-bold text-foreground">{t.pillars.title}</h2>

  <div class="grid gap-6 md:grid-cols-3">
    {t.pillars.items.map((item, i) => (
      <a href={`#${t.pillarDetails[i].id}`} class="group rounded-xl border border-border bg-card p-8 transition hover:border-muted-foreground/30">
        <!-- Icon -->
        <div class={`mb-5 inline-flex rounded-lg border p-3 ${colors[i]}`}>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[item.icon]} />
        </div>

        <!-- Benefit headline -->
        <h3 class="text-lg font-semibold text-foreground">{item.benefit}</h3>

        <!-- Description -->
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.desc}</p>
      </a>
    ))}
  </div>
</section>
