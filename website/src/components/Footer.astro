---
import type zh from '../i18n/zh.json';

interface Props {
  t: typeof zh;
}

const { t } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<footer class="border-t border-border">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-6 py-12 text-center">
    <!-- Logo -->
    <a href={`${base}`} class="flex items-center gap-2 text-foreground">
      <img src={`${base}favicon.svg`} alt="SkillForge" class="h-6 w-6" />
      <span class="font-semibold">SkillForge</span>
    </a>

    <p class="text-sm text-muted-foreground">{t.footer.tagline}</p>

    <!-- Links -->
    <div class="flex gap-4 text-sm text-muted-foreground">
      <a href="https://github.com/cypsh1/SkillForge" target="_blank" rel="noopener" class="transition hover:text-foreground">GitHub</a>
      <span class="text-border">|</span>
      <a href="https://github.com/cypsh1/SkillForge/issues" target="_blank" rel="noopener" class="transition hover:text-foreground">{t.footer.feedback}</a>
    </div>

    <p class="text-xs text-muted-foreground/60">&copy; 2026 SkillForge &middot; {t.footer.license}</p>
  </div>
</footer>
