---
import type zh from '../i18n/zh.json';

interface Props {
  t: typeof zh;
}

const { t } = Astro.props;
const releasesUrl = 'https://github.com/cypsh1/SkillForge/releases';

const platformIcons: Record<string, string> = {
  apple: '<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>',
  windows: '<path d="M3 5.548l7.197-0.993v6.958H3V5.548zM3 18.452l7.197 0.993v-6.958H3V18.452zM11.197 4.44L21 3v8.513h-9.803V4.44zM11.197 19.56L21 21v-8.513h-9.803V19.56z"/>',
  linux: '<path d="M12 2C8.5 2 7 5.5 7 8c0 2 .5 3 1 4.5.5 1.5 1 2 1.5 3 .3.5.5 1.5.5 2.5 0 2-1 3-1 3h8s-1-1-1-3c0-1 .2-2 .5-2.5.5-1 1-1.5 1.5-3S17 10 17 8c0-2.5-1.5-6-5-6z"/><path d="M9 22c0 .5.5 1 1 1h4c.5 0 1-.5 1-1"/><circle cx="10" cy="7" r="0.5"/><circle cx="14" cy="7" r="0.5"/>',
};
---

<section id="download" class="reveal mx-auto max-w-6xl px-6 py-24">
  <div class="text-center">
    <h2 class="text-3xl font-bold text-foreground">{t.download.title}</h2>
    <p class="mt-3 text-muted-foreground">{t.download.subtitle}</p>
    <span class="mt-1 inline-block text-xs text-muted-foreground/60">{t.download.version}</span>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-3">
    {t.download.platforms.map((platform) => (
      <div class="flex flex-col items-center gap-4 rounded-xl border border-border bg-card p-8">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-muted-foreground" set:html={platformIcons[platform.icon]} />
        <div class="text-center">
          <h3 class="text-lg font-semibold text-foreground">{platform.name}</h3>
          <span class="text-xs text-muted-foreground">{platform.format}</span>
        </div>
        <a href={releasesUrl} target="_blank" rel="noopener" class="w-full rounded-lg bg-gradient-to-r from-brand-purple to-brand-cyan px-6 py-2.5 text-center text-sm font-medium text-white transition hover:opacity-90">
          {t.download.button}
        </a>
      </div>
    ))}
  </div>

  <p class="mt-8 text-center text-sm text-muted-foreground">
    <a href={releasesUrl} target="_blank" rel="noopener" class="underline underline-offset-4 transition hover:text-foreground">
      {t.download.releases}
    </a>
  </p>
</section>
